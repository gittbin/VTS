# Sao chép file này thành .env rồi điền giá trị:  cp .env.example .env
# LƯU Ý: .env chứa bí mật -> KHÔNG commit lên git.

# --- Bắt buộc ---
# Khóa ký JWT (HMAC-SHA256) — tối thiểu 32 ký tự.
JWT_SECRET=doi-thanh-chuoi-bi-mat-toi-thieu-32-ky-tu

# --- MongoDB ---
# Để trống -> dùng MongoDB local trong docker-compose (service "mongo").
# Hoặc trỏ tới MongoDB Atlas, vd:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vts?retryWrites=true&w=majority
MONGODB_URI=

# Thông tin đăng nhập MongoDB local (chỉ dùng khi chạy service "mongo").
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example

# --- Tùy chọn JVM ---
JAVA_OPTS=-Xms256m -Xmx512m
